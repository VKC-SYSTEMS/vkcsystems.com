# Copy this file to .env and fill in real values for local development.
# In production, set these in the Vercel project's Environment Variables.

# ---- Microsoft 365 / Graph API (server-only) ----
# Azure AD app registration: portal.azure.com -> Entra ID -> App registrations
# The app needs Microsoft Graph "Mail.Send" application permission with admin consent.
# Strongly recommended: scope the app to a single mailbox via New-ApplicationAccessPolicy.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# UPN or object ID of the mailbox the form should send FROM.
# Example: notifications@vkcsystems.com (a dedicated mailbox is best practice).
M365_SENDER_USER_ID=

# Where inquiries are delivered. Defaults to info@vkcsystems.com if unset.
M365_RECIPIENT_EMAIL=info@vkcsystems.com

# ---- Cloudflare Turnstile ----
# Get keys at: dash.cloudflare.com -> Turnstile -> Add site
# Site key is public (exposed in HTML); secret stays server-only.
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
