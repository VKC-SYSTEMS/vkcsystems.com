---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Analytics from '@vercel/analytics/astro';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs?: BreadcrumbItem[];
  serviceName?: string;
  faqs?: FaqItem[];
}

const {
  title,
  description,
  canonical,
  breadcrumbs,
  serviceName,
  faqs,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://vkcsystems.com';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();

const businessId = `${siteUrl}/#business`;
const websiteId = `${siteUrl}/#website`;

const serviceCatalog = [
  { name: 'Network Engineering & Infrastructure', url: `${siteUrl}/solutions/networking` },
  { name: 'CCTV & Video Surveillance Systems', url: `${siteUrl}/solutions/cctv` },
  { name: 'Access Control Systems', url: `${siteUrl}/solutions/access-control` },
  { name: 'Public Address & Intercom Systems', url: `${siteUrl}/solutions/public-address` },
  { name: 'Custom Communication Cabinets', url: `${siteUrl}/solutions/communication-cabinets` },
  { name: 'CADD Engineering & Documentation', url: `${siteUrl}/solutions/cadd` },
  { name: 'VoIP Phone Systems', url: `${siteUrl}/solutions/voip` },
  { name: 'Office IT & Managed Services', url: `${siteUrl}/solutions/office-it` },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": businessId,
  "name": "VKC Systems",
  "legalName": "VKC Systems Inc.",
  "description": description,
  "url": siteUrl,
  "telephone": "+1-201-374-0252",
  "email": "info@vkcsystems.com",
  "foundingDate": "2014",
  "priceRange": "$$$",
  "paymentAccepted": "Check, Wire Transfer, ACH, Net 30/60 Invoice",
  "currenciesAccepted": "USD",
  "slogan": "Engineering-driven infrastructure for mission-critical environments.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "89 Leuning St Suite 1E",
    "addressLocality": "South Hackensack",
    "addressRegion": "NJ",
    "postalCode": "07606",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.8621,
    "longitude": -74.0507
  },
  "areaServed": [
    { "@type": "City", "name": "New York" },
    { "@type": "City", "name": "Jersey City" },
    { "@type": "City", "name": "Newark" },
    { "@type": "State", "name": "New Jersey" },
    { "@type": "State", "name": "New York" },
    {
      "@type": "GeoCircle",
      "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 40.8621, "longitude": -74.0507 },
      "geoRadius": "100 mi"
    }
  ],
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": [
      "Monday",
      "Tuesday",
      "Wednesday",
      "Thursday",
      "Friday"
    ],
    "opens": "07:00",
    "closes": "15:00"
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "telephone": "+1-201-374-0252",
      "email": "info@vkcsystems.com",
      "contactType": "customer service",
      "areaServed": "US",
      "availableLanguage": ["English", "Spanish"]
    }
  ],
  "knowsAbout": [
    "Network infrastructure design",
    "CCTV and video surveillance systems",
    "Access control systems",
    "Public address and intercom systems",
    "Fiber optic cabling",
    "VoIP phone systems",
    "Communication cabinet fabrication",
    "Systems integration",
    "Transit communications",
    "Public sector infrastructure"
  ],
  "award": [
    "Minority Business Enterprise (MBE) Certified",
    "Disadvantaged Business Enterprise (DBE) Certified",
    "OSHA 30 Certified",
    "Track Safety Training",
    "Cisco CCNA / CCNP",
    "CompTIA Network+",
    "CSPM"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Systems Integration Services",
    "itemListElement": serviceCatalog.map((s) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": s.name,
        "url": s.url,
        "provider": { "@id": businessId },
      },
    })),
  },
  "image": `${siteUrl}/og-image.jpg`,
  "logo": `${siteUrl}/logo-color.png`,
  "sameAs": [
    "https://www.facebook.com/vkcsystemsinc",
    "https://www.instagram.com/vkcsystems/",
    "https://www.linkedin.com/company/vkc-systems-inc"
  ]
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": websiteId,
  "url": siteUrl,
  "name": "VKC Systems",
  "description": "MBE/DBE certified systems integrator serving the NYC metro area — networking, CCTV, access control, and communications infrastructure.",
  "inLanguage": "en-US",
  "publisher": { "@id": businessId },
};

const breadcrumbLd = breadcrumbs ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": breadcrumbs.map((item, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": item.name,
    "item": item.url,
  })),
} : null;

const serviceLd = serviceName ? {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": serviceName,
  "description": description,
  "provider": { "@id": businessId },
  "areaServed": {
    "@type": "GeoCircle",
    "geoMidpoint": { "@type": "GeoCoordinates", "latitude": 40.8621, "longitude": -74.0507 },
    "geoRadius": "100 mi",
  },
  "url": canonicalUrl,
} : null;

const faqLd = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer,
    },
  })),
} : null;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#dd3333" />

    <!-- Font Preloads -->
    <link rel="preload" href="/fonts/inter-400.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-700.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

    <!-- Self-hosted Inter font -->
    <style>
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 400; font-display: swap; src: url('/fonts/inter-400.woff2') format('woff2'); }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 500; font-display: swap; src: url('/fonts/inter-500.woff2') format('woff2'); }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 600; font-display: swap; src: url('/fonts/inter-600.woff2') format('woff2'); }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 700; font-display: swap; src: url('/fonts/inter-700.woff2') format('woff2'); }
      @font-face { font-family: 'Inter'; font-style: normal; font-weight: 800; font-display: swap; src: url('/fonts/inter-800.woff2') format('woff2'); }
    </style>

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteLd)} />
    {breadcrumbLd && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />}
    {serviceLd && <script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />}
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </head>
  <body class="flex min-h-screen flex-col bg-white font-sans text-vkc-dark antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-vkc-red focus:px-4 focus:py-2 focus:text-white focus:outline-none">
      Skip to content
    </a>
    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
    <Analytics />
  </body>
</html>
