---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'VoIP Engineering & Design',
    items: [
      'VoIP system architecture and design',
      'SIP-based system configuration and call flow design',
      'PBX system engineering, deployment, and system optimization',
      'Redundancy and failover planning for voice systems',
    ],
  },
  {
    title: 'Network Integration for Voice',
    items: [
      'Network readiness assessments for VoIP',
      'Quality of Service (QoS) configuration and optimization',
      'VLAN configuration and traffic segmentation for voice',
      'Integration with existing LAN/WAN infrastructure',
    ],
  },
  {
    title: 'System Configuration & Programming',
    items: [
      'IP phone system configuration and provisioning',
      'Call routing, dial plans, and system logic configuration',
      'Integration with third-party communication platforms',
      'Unified communications system configuration',
    ],
  },
  {
    title: 'Maintenance & Support',
    items: [
      'Ongoing system monitoring and support',
      'Performance tuning and system optimization',
      'System upgrades and scalability planning',
      'Troubleshooting and issue resolution',
    ],
  },
];

const integrationSystems = [
  'Network infrastructure systems',
  'Security and access control systems',
  'Public address and communication systems',
];
---

<BaseLayout
  title="VoIP Systems Engineering & Integration | VKC Systems"
  description="Enterprise VoIP engineering, SIP/PBX configuration, QoS optimization, and network-integrated voice systems for business and infrastructure environments."
  serviceName="VoIP Systems Engineering & Integration"
  breadcrumbs={[
    { name: "Home", url: "https://vkcsystems.com/" },
    { name: "Solutions", url: "https://vkcsystems.com/solutions" },
    { name: "VoIP", url: "https://vkcsystems.com/solutions/voip" },
  ]}
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Solutions</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        VoIP Systems Engineering &amp; Integration
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        Enterprise-grade VoIP solutions engineered for reliability, performance, and seamless
        integration within critical network infrastructure environments.
      </p>
    </div>
  </section>

  <!-- Back to Solutions Link -->
  <div class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <a
        href="/solutions"
        class="inline-flex items-center text-sm font-medium text-vkc-gray transition-colors duration-200 hover:text-vkc-red"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>
    </div>
  </div>

  <!-- Overview Section -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          VoIP Infrastructure Overview
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems provides engineering-driven VoIP solutions that integrate directly with
          existing network infrastructure.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          We design and deploy voice systems that prioritize call quality, network efficiency,
          and system resilience — ensuring consistent performance across business and
          infrastructure environments.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our approach focuses on proper network design for voice traffic, including bandwidth
          management, Quality of Service (QoS), and system redundancy.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Unlike traditional VoIP providers, VKC Systems delivers network-integrated voice
          solutions engineered as part of a complete infrastructure ecosystem.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          VoIP Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2">
        {categories.map((category) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-bold text-vkc-dark">{category.title}</h3>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-vkc-red"></div>
            <ul class="mt-5 space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-base text-vkc-gray">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Built for Reliable Communication -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Reliability</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Built for Reliable Communication
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems designs VoIP systems for environments where communication reliability
          and system performance are essential.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our solutions are engineered to deliver consistent call quality, minimize downtime,
          and support long-term operational requirements.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          System designs incorporate redundancy and failover strategies to maintain continuous
          communication during network or system disruptions.
        </p>
        <p class="mt-4 text-base leading-relaxed text-vkc-gray">
          All VoIP systems are designed and configured in accordance with industry best practices,
          project specifications, and network performance requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- Integrated with Network Infrastructure -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Integration</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Integrated with Network Infrastructure
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our VoIP solutions are designed as part of a broader infrastructure ecosystem,
          ensuring seamless integration with:
        </p>
        <ul class="mt-6 space-y-3">
          {integrationSystems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-vkc-dark sm:text-3xl">
        Precision. Performance. Reliability.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-vkc-gray">
        Every VoIP system we deploy is engineered with a focus on call quality, system stability,
        and long-term performance. Our team ensures that voice communication systems operate
        reliably within real-world network environments.
      </p>
    </div>
  </section>


  <!-- ============================================ -->
  <!--          PROJECT EXPERIENCE SECTION           -->
  <!-- ============================================ -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Project Experience</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
        Proven in the Field
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-vkc-gray">
        Our systems have been deployed across transit infrastructure, substations, tunnels, rail stations, and government facilities.
      </p>
      <a
        href="/projects"
        class="mt-6 inline-flex items-center text-sm font-semibold text-vkc-red transition hover:text-vkc-red-dark"
      >
        View Related Projects &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================ -->
  <!--             AGENCIES STRIP                    -->
  <!-- ============================================ -->
  <section class="bg-vkc-light py-12 sm:py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-medium text-vkc-gray">
        Trusted by agencies across the tri-state region:
      </p>
      <p class="mt-3 text-sm font-semibold tracking-wide text-vkc-dark">
        MTA &bull; NYCT &bull; LIRR &bull; NJ Transit &bull; Port Authority &bull; NYC DEP
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Need a VoIP Solution?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our team is ready to design and implement a VoIP system tailored to your infrastructure
        and communication needs.
      </p>
      <p class="mt-2 text-base text-gray-400">
        Trusted on projects across the New York metropolitan area.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Request a Consultation
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Capabilities
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
