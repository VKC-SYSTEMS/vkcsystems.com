---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Engineering & Design',
    items: [
      'Camera placement engineering and system coverage design',
      'Surveillance system architecture and layout planning',
      'Resolution, storage, and bandwidth planning',
      'Field surveys and engineering assessments',
    ],
  },
  {
    title: 'Infrastructure & Systems',
    items: [
      'Custom CCTV cabinet fabrication',
      'Camera hardware deployment and infrastructure installation',
      'IP-based surveillance system design',
      'Network-integrated video surveillance systems',
    ],
  },
  {
    title: 'Testing & Commissioning',
    items: [
      'Video Management System (VMS) testing and validation',
      'System performance verification',
      'Factory Acceptance Testing (FAT)',
      'Site Acceptance Testing (SAT)',
    ],
  },
  {
    title: 'Deployment & Integration',
    items: [
      'Camera configuration and system calibration',
      'VMS programming and system setup',
      'Integration into existing infrastructure environments',
      'System commissioning and operational validation',
    ],
  },
];

const compliance = [
  'MTA / NYCT standards',
  'Safety and operational regulations',
  'Environmental and equipment requirements (NEMA ratings, temperature control, etc.)',
];
---

<BaseLayout
  title="CCTV Systems Engineering & Integration | VKC Systems"
  description="CCTV systems engineering, integration, and validation for transit and mission-critical infrastructure environments. FAT/SAT testing, VMS integration, and custom cabinet fabrication."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Solutions</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        CCTV Systems Engineering &amp; Integration
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        High-performance CCTV solutions designed for transit, transportation, and public sector
        projects — ensuring reliable video capture, recording, and system-wide visibility across
        complex operational environments.
      </p>
    </div>
  </section>

  <!-- Back to Solutions Link -->
  <div class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <a
        href="/solutions"
        class="inline-flex items-center text-sm font-medium text-vkc-gray transition-colors duration-200 hover:text-vkc-red"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>
    </div>
  </div>

  <!-- Overview Section -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          CCTV Systems Overview
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems provides end-to-end surveillance system integration, combining engineering
          expertise, field execution, and technical precision to support large-scale infrastructure
          deployments.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          From initial system design through final commissioning, we ensure every CCTV system is
          engineered for performance, reliability, and long-term operational stability.
        </p>
      </div>
    </div>
  </section>

  <!-- Core CCTV Capabilities -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Core CCTV Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2">
        {categories.map((category) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-bold text-vkc-dark">{category.title}</h3>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-vkc-red"></div>
            <ul class="mt-5 space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-base text-vkc-gray">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Compliance & Standards -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Standards</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Compliance &amp; Standards
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers CCTV systems that meet the strict requirements of transit and
          public sector agencies. Our experience includes compliance with:
        </p>
        <ul class="mt-6 space-y-3">
          {compliance.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-base leading-relaxed text-vkc-gray">
          Every system is designed to meet regulatory requirements while ensuring long-term
          operational reliability.
        </p>
      </div>
    </div>
  </section>

  <!-- Built for Critical Environments -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Reliability</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Built for Critical Environments
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers surveillance systems designed for environments where visibility,
          reliability, and performance are non-negotiable.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our systems are engineered to support continuous operation in complex infrastructure
          environments, ensuring consistent monitoring, secure data handling, and long-term
          system stability.
        </p>
      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-vkc-dark sm:text-3xl">
        Precision. Performance. Reliability.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-vkc-gray">
        Every surveillance system we deploy is engineered with a focus on accuracy, efficiency,
        and long-term durability. Our team combines engineering expertise with field experience
        to deliver solutions that perform under real-world conditions and meet the demands of
        critical infrastructure environments.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Let's Design Your Surveillance System
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our team is ready to engineer, integrate, and deliver CCTV infrastructure tailored
        to your project requirements.
      </p>
      <p class="mt-2 text-base text-gray-400">
        Trusted on complex infrastructure projects across the New York metropolitan area.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Contact Us
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Solutions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
