---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Engineering & Design',
    items: [
      'Access control system architecture and layout design',
      'Door hardware integration and control system planning',
      'Credential and identity system design',
      'Field surveys and system assessments',
    ],
  },
  {
    title: 'Infrastructure & Systems',
    items: [
      'Access control panel and cabinet integration',
      'IP-based access control system architecture and implementation',
      'Integration with CCTV, intrusion, and building systems',
      'Power redundancy and system reliability planning',
    ],
  },
  {
    title: 'Testing & Commissioning',
    items: [
      'System functionality testing and validation',
      'Credential and access level verification',
      'Factory Acceptance Testing (FAT)',
      'Site Acceptance Testing (SAT)',
      'Access control database and event validation',
    ],
  },
  {
    title: 'Deployment & Integration',
    items: [
      'System configuration and programming',
      'Lenel OnGuard system integration',
      'Integration with existing infrastructure environments',
      'Commissioning and operational validation',
    ],
  },
];

const unifiedSystems = [
  'Video surveillance systems (CCTV)',
  'Intrusion detection systems',
  'Building management systems',
  'Network infrastructure environments',
];
---

<BaseLayout
  title="Access Control Systems Engineering | VKC Systems"
  description="Access control systems engineering, integration, and validation for transit and infrastructure environments. Lenel OnGuard, FAT/SAT testing, and unified security platforms."
  serviceName="Access Control Systems Engineering"
  breadcrumbs={[
    { name: "Home", url: "https://vkcsystems.com/" },
    { name: "Solutions", url: "https://vkcsystems.com/solutions" },
    { name: "Access Control", url: "https://vkcsystems.com/solutions/access-control" },
  ]}
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Solutions</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Access Control Systems Engineering &amp; Integration
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        Secure, scalable control of physical access across transit systems and commercial
        facilities — ensuring reliable system performance, centralized management, and seamless
        integration with broader infrastructure systems.
      </p>
    </div>
  </section>

  <!-- Back to Solutions Link -->
  <div class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <a
        href="/solutions"
        class="inline-flex items-center text-sm font-medium text-vkc-gray transition-colors duration-200 hover:text-vkc-red"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>
    </div>
  </div>

  <!-- Overview Section -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Access Control Systems Overview
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers end-to-end access control system integration, combining
          engineering expertise with field execution to support complex infrastructure
          deployments.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          From system architecture through commissioning, we ensure every access control system
          is engineered for reliability, scalability, and long-term operational performance.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our experience includes large-scale access control deployments across transit and
          infrastructure environments, supporting complex operational and security requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- Core Access Control Capabilities -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Core Access Control Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2">
        {categories.map((category) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-bold text-vkc-dark">{category.title}</h3>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-vkc-red"></div>
            <ul class="mt-5 space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-base text-vkc-gray">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Unified Security & Infrastructure Systems -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Integration</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Unified Security &amp; Infrastructure Systems
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers access control systems that integrate with broader infrastructure
          platforms, providing centralized visibility and control across:
        </p>
        <ul class="mt-6 space-y-3">
          {unifiedSystems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Built for Critical Environments -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Reliability</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Built for Critical Environments
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers access control systems designed for environments where security,
          reliability, and operational control are non-negotiable.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our systems are engineered to support continuous operation, secure access management,
          and seamless integration across complex infrastructure environments.
        </p>
      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-vkc-dark sm:text-3xl">
        Precision. Performance. Reliability.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-vkc-gray">
        Every access control system we deploy is engineered with a focus on security, scalability,
        and operational performance. Our team combines engineering expertise with field experience
        to deliver systems that perform reliably in demanding environments.
      </p>
    </div>
  </section>


  <!-- ============================================ -->
  <!--          PROJECT EXPERIENCE SECTION           -->
  <!-- ============================================ -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Project Experience</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
        Proven in the Field
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-vkc-gray">
        Our systems have been deployed across transit infrastructure, substations, tunnels, rail stations, and government facilities.
      </p>
      <a
        href="/projects"
        class="mt-6 inline-flex items-center text-sm font-semibold text-vkc-red transition hover:text-vkc-red-dark"
      >
        View Related Projects &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================ -->
  <!--             AGENCIES STRIP                    -->
  <!-- ============================================ -->
  <section class="bg-vkc-light py-12 sm:py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-medium text-vkc-gray">
        Trusted by agencies across the tri-state region:
      </p>
      <p class="mt-3 text-sm font-semibold tracking-wide text-vkc-dark">
        MTA &bull; NYCT &bull; LIRR &bull; NJ Transit &bull; Port Authority &bull; NYC DEP
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Let's Design Your Access Control System
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our team is ready to engineer, integrate, and deliver access control infrastructure
        tailored to your project requirements.
      </p>
      <p class="mt-2 text-base text-gray-400">
        Trusted on complex infrastructure projects across the New York metropolitan area.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Request a Consultation
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Capabilities
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
