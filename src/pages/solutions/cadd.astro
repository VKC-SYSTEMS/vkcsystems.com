---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Engineering & Design Documentation',
    items: [
      'Conceptual design drawings and system layouts',
      'Communication riser diagrams (logical and physical)',
      'Network and system architecture diagrams',
      'Equipment layout and cabinet drawings',
    ],
  },
  {
    title: 'Technical Drawings & Drafting',
    items: [
      'AutoCAD drafting and production of detailed engineering drawings',
      'Wiring diagrams and interconnection drawings',
      'Installation plans and construction coordination drawings',
      'Coordination drawings across multiple trades',
    ],
  },
  {
    title: 'Project Documentation & Submittals',
    items: [
      'Technical writing and engineering documentation',
      'Submittal packages and supporting documentation',
      'Design-to-fabrication quality control documentation',
      'Compliance and standards-based documentation',
    ],
  },
  {
    title: 'As-Built & Closeout Documentation',
    items: [
      'As-built drawings and system updates',
      'Field markups and documentation reconciliation',
      'Cable certification and testing documentation',
      'Final project documentation for turnover and operations',
    ],
  },
];

const integrationSystems = [
  'Network infrastructure systems',
  'Video surveillance systems (CCTV)',
  'Access control systems',
  'Public address and communication systems',
];
---

<BaseLayout
  title="CADD Engineering & Documentation | VKC Systems"
  description="Engineering-focused CADD services for transit and infrastructure projects. AutoCAD drafting, technical documentation, as-built drawings, and submittal packages."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Solutions</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        CADD Engineering &amp; Documentation Services
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        Precise technical documentation, engineering drawings, and project deliverables
        for complex transit, transportation, and commercial infrastructure projects.
      </p>
    </div>
  </section>

  <!-- Back to Solutions Link -->
  <div class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <a
        href="/solutions"
        class="inline-flex items-center text-sm font-medium text-vkc-gray transition-colors duration-200 hover:text-vkc-red"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>
    </div>
  </div>

  <!-- Overview Section -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Engineering Documentation Overview
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems supports the full project lifecycle by delivering structured, accurate,
          and standards-compliant engineering documentation.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          From conceptual design through final as-built drawings, our CADD team ensures all
          documentation aligns with project specifications, field conditions, and system
          integration requirements.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          We work closely with engineers, project managers, and field teams to develop
          documentation that supports installation, testing, commissioning, and long-term
          system maintenance.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Unlike traditional drafting services, VKC Systems delivers engineering-driven
          documentation that directly supports system integration, field execution, and
          project closeout requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- What We Deliver -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          CADD Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2">
        {categories.map((category) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-bold text-vkc-dark">{category.title}</h3>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-vkc-red"></div>
            <ul class="mt-5 space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-base text-vkc-gray">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Built for Complex Infrastructure Projects -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Reliability</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Built for Complex Infrastructure Projects
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers documentation solutions designed for environments where accuracy,
          coordination, and compliance are critical.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our experience includes large-scale transit and infrastructure projects where precise
          documentation is required to support system integration, inspections, and long-term
          operational reliability.
        </p>
        <p class="mt-4 text-base leading-relaxed text-vkc-gray">
          All documentation is developed in accordance with applicable project specifications,
          industry standards, and client requirements.
        </p>
      </div>
    </div>
  </section>

  <!-- Integrated with System Engineering -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Integration</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Integrated with System Engineering
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our CADD services are not standalone drafting — they are fully integrated into the
          engineering, coordination, and deployment of complete infrastructure systems, including:
        </p>
        <ul class="mt-6 space-y-3">
          {integrationSystems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-vkc-dark sm:text-3xl">
        Precision. Coordination. Reliability.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-vkc-gray">
        Every drawing and document we produce is developed with a focus on accuracy, clarity,
        and real-world usability. Our team ensures that documentation supports both field
        execution and long-term system performance.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Need Engineering Documentation Support?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our CADD team is ready to support your project with accurate, structured, and fully
        coordinated engineering documentation.
      </p>
      <p class="mt-2 text-base text-gray-400">
        Trusted on complex infrastructure projects across the New York metropolitan area.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Contact Us
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Solutions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
