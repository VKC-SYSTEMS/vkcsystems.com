---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  {
    title: 'Engineering & Design',
    items: [
      'Cabinet layout and equipment configuration design',
      'Power distribution and electrical system planning',
      'Thermal management and ventilation design',
      'Field requirements analysis and site-specific engineering',
    ],
  },
  {
    title: 'Infrastructure & Fabrication',
    items: [
      'Custom cabinet fabrication, assembly, and system integration',
      'NEMA-rated enclosure design and compliance',
      'Integration of power, cooling, and control systems',
      'Equipment mounting and structured system layout',
    ],
  },
  {
    title: 'Testing & Commissioning',
    items: [
      'Pre-deployment system validation and testing',
      'Power and environmental system verification',
      'Equipment integration testing',
      'Factory Acceptance Testing (FAT)',
    ],
  },
  {
    title: 'Deployment & Integration',
    items: [
      'Coordination with field installation teams, contractors, and project stakeholders',
      'System integration with network, CCTV, access control, and PA systems',
      'Equipment configuration and connectivity validation',
      'Pre-deployment staging and readiness verification',
    ],
  },
];

const qaProcess = [
  'Engineering review and design validation',
  'Bill of materials (BOM) development and component selection',
  'Controlled fabrication and assembly process',
  'Internal quality checks and system verification',
  'Pre-deployment staging and testing',
];

const integrationSystems = [
  'Network infrastructure systems',
  'Video surveillance systems (CCTV)',
  'Access control systems',
  'Public address and communication systems',
];
---

<BaseLayout
  title="Custom Communication Cabinets | VKC Systems"
  description="Custom communication cabinet engineering, fabrication, and integration for transit and infrastructure environments. NEMA-rated enclosures, thermal management, and FAT testing."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Solutions</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Custom Communication Cabinet Engineering &amp; Fabrication
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        Purpose-built cabinets to house and protect network, surveillance, access control, and
        communication systems — ensuring reliable operation, environmental protection, and
        long-term system performance in demanding transit and industrial environments.
      </p>
    </div>
  </section>

  <!-- Back to Solutions Link -->
  <div class="bg-white border-b border-gray-100">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
      <a
        href="/solutions"
        class="inline-flex items-center text-sm font-medium text-vkc-gray transition-colors duration-200 hover:text-vkc-red"
      >
        <svg
          class="mr-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="2"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>
    </div>
  </div>

  <!-- Overview Section -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h2 class="text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Communication Cabinet Systems Overview
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems delivers fully engineered cabinet solutions designed to support complex
          infrastructure systems.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          From design and layout through fabrication and system integration, every cabinet is
          built to meet project-specific requirements for power distribution, thermal management,
          equipment mounting, and long-term operational reliability.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Unlike standard off-the-shelf enclosures, VKC Systems designs and fabricates fully
          integrated cabinet solutions tailored to the operational, environmental, and technical
          requirements of each project.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our cabinet solutions have been deployed across large-scale transit and infrastructure
          projects throughout the New York metropolitan area.
        </p>
      </div>
    </div>
  </section>

  <!-- Core Cabinet Engineering Capabilities -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Core Cabinet Engineering Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-8 sm:grid-cols-2">
        {categories.map((category) => (
          <div class="rounded-2xl border border-gray-100 bg-white p-8 shadow-sm">
            <h3 class="text-xl font-bold text-vkc-dark">{category.title}</h3>
            <div class="mt-2 h-0.5 w-10 rounded-full bg-vkc-red"></div>
            <ul class="mt-5 space-y-3">
              {category.items.map((item) => (
                <li class="flex items-start gap-3">
                  <svg
                    class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2.5"
                    stroke="currentColor"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                  <span class="text-base text-vkc-gray">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Fabrication & Quality Assurance Process -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Quality</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Fabrication &amp; Quality Assurance Process
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems follows a structured fabrication and quality assurance process to ensure
          every cabinet meets project specifications and operational requirements.
        </p>
        <ul class="mt-6 space-y-3">
          {qaProcess.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 text-base leading-relaxed text-vkc-gray">
          Every cabinet is built with a focus on precision, consistency, and long-term performance
          in real-world environments.
        </p>
      </div>
    </div>
  </section>

  <!-- Built for Harsh & Critical Environments -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Reliability</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          Built for Harsh &amp; Critical Environments
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          VKC Systems designs cabinets for environments where reliability, protection, and
          performance are non-negotiable.
        </p>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Our cabinets are engineered to withstand harsh environmental conditions, including
          temperature extremes, moisture, dust, and vibration — ensuring continuous operation
          of critical systems in transit and industrial environments.
        </p>
        <p class="mt-4 text-base leading-relaxed text-vkc-gray">
          All cabinet systems are designed and fabricated in accordance with applicable industry
          standards and project specifications.
        </p>
      </div>
    </div>
  </section>

  <!-- System Integration Ready -->
  <section class="bg-white py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Integration</p>
        <h2 class="mt-3 text-3xl font-extrabold tracking-tight text-vkc-dark sm:text-4xl">
          System Integration Ready
        </h2>
        <div class="mt-2 h-1 w-16 rounded-full bg-vkc-red"></div>
        <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
          Every cabinet is designed as part of a larger infrastructure ecosystem, supporting
          seamless integration with:
        </p>
        <ul class="mt-6 space-y-3">
          {integrationSystems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base text-vkc-gray">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Tagline Section -->
  <section class="bg-vkc-light py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-2xl font-extrabold tracking-tight text-vkc-dark sm:text-3xl">
        Precision. Performance. Reliability.
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg leading-relaxed text-vkc-gray">
        Every cabinet we fabricate is engineered with a focus on durability, system performance,
        and long-term reliability. Our team combines engineering expertise with fabrication
        experience to deliver solutions that meet the demands of real-world infrastructure
        environments.
      </p>
    </div>
  </section>


  <!-- ============================================ -->
  <!--          PROJECT EXPERIENCE SECTION           -->
  <!-- ============================================ -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Project Experience</p>
      <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
        Proven in the Field
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-vkc-gray">
        Our systems have been deployed across transit infrastructure, substations, tunnels, rail stations, and government facilities.
      </p>
      <a
        href="/projects"
        class="mt-6 inline-flex items-center text-sm font-semibold text-vkc-red transition hover:text-vkc-red-dark"
      >
        View Related Projects &rarr;
      </a>
    </div>
  </section>

  <!-- ============================================ -->
  <!--             AGENCIES STRIP                    -->
  <!-- ============================================ -->
  <section class="bg-vkc-light py-12 sm:py-14">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-medium text-vkc-gray">
        Trusted by agencies across the tri-state region:
      </p>
      <p class="mt-3 text-sm font-semibold tracking-wide text-vkc-dark">
        MTA &bull; NYCT &bull; LIRR &bull; NJ Transit &bull; Port Authority &bull; NYC DEP
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Let's Design Your Cabinet Solution
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our team is ready to engineer, fabricate, and deliver custom communication cabinets
        tailored to your project requirements.
      </p>
      <p class="mt-2 text-base text-gray-400">
        Trusted on complex infrastructure projects across the New York metropolitan area.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Request a Consultation
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Capabilities
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
