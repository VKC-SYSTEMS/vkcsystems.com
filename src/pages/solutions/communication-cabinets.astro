---
import BaseLayout from '../../layouts/BaseLayout.astro';

const capabilities = [
  'Custom cabinet design and fabrication',
  'NEMA-rated enclosures',
  'Temperature control systems',
  'CCTV integration cabinets',
  'VoIP system enclosures',
  'Secure access control housings',
  'VMS testing and integration',
  'PSLAN upgrade cabinets',
  'Data cabinet construction per location specs',
];
---

<BaseLayout
  title="Communication Cabinets | VKC Systems"
  description="VKC Systems designs and fabricates custom network cabinets for CCTV, VoIP, secure access control, VMS testing/integration, and PSLAN upgrades with NEMA rating and temperature control."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Breadcrumb -->
      <a
        href="/solutions"
        class="mb-8 inline-flex items-center gap-2 text-sm font-medium text-gray-400 transition-colors duration-200 hover:text-vkc-red"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
        </svg>
        Back to Solutions
      </a>

      <div class="text-center">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Our Solutions</p>
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Communication Cabinets
        </h1>
        <div class="mx-auto mt-4 h-1 w-20 rounded-full bg-vkc-red"></div>
      </div>
    </div>
  </section>

  <!-- Overview Section -->
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-vkc-dark sm:text-4xl">
        Overview
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-vkc-gray sm:text-xl">
        VKC Systems designs and fabricates custom network cabinets for CCTV, VoIP, secure access
        control, VMS testing and integration, and PSLAN upgrades. Our cabinets feature NEMA rating
        compliance and temperature control systems, built to withstand the demanding conditions of
        transit and industrial environments.
      </p>
    </div>
  </section>

  <!-- Key Capabilities Section -->
  <section class="bg-vkc-light py-20 sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">What We Deliver</p>
        <h2 class="mt-3 text-3xl font-bold text-vkc-dark sm:text-4xl">
          Key Capabilities
        </h2>
      </div>

      <div class="mx-auto mt-12 grid max-w-5xl gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {capabilities.map((capability) => (
          <div class="flex items-start gap-3 rounded-xl bg-white p-5 shadow-sm transition-shadow duration-200 hover:shadow-md">
            <svg
              class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="2.5"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
            </svg>
            <span class="text-base font-medium text-vkc-dark">{capability}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-vkc-dark py-20 sm:py-28">
    <div class="mx-auto max-w-4xl px-4 text-center sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
        Need a custom cabinet solution?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-gray-300">
        Our engineering team designs and fabricates cabinets tailored to your exact specifications and environment requirements.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/contact"
          class="inline-flex items-center rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Get a Quote
        </a>
        <a
          href="/solutions"
          class="inline-flex items-center rounded-lg border-2 border-white/20 px-8 py-3.5 text-base font-semibold text-white transition-colors duration-200 hover:border-white hover:bg-white/10"
        >
          View All Solutions
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
