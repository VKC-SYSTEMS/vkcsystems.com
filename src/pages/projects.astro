const previousProjectsLeft = [
  'LIRR 6240 3rd Track - 5 Stations',
  'A-37150D - Livonia',
  'E-34025R - Elevators GCT',
  'C-43751 - Power and HVAC Upgrade at PCC RCC',
  'P-36444 - Rutgers Tube Rehabilitation',
  'QM-81 - Rehabilitation of Tunnel Controls and Communications at QMT and HCT',
];

const previousProjectsRight = [
  'CS-179 - East Side Access',
  'S-33932 - Life Cycle Replacement Code System Phase I',
  'E-30512 - Replace Escalators',
  'LIRR - 3rd Track Temporary WiFi',
  'P-80692 - Tottenville Substation',
  'MNR 58050 - CSI Package',
