---
import BaseLayout from '../layouts/BaseLayout.astro';

const responsibilities = [
  'Install and service IP and analog CCTV systems',
  'Install and troubleshoot NVRs, DVRs, PoE switches, and network hardware',
  'Install access control systems (readers, strikes, maglocks, REX devices, panels)',
  'Pull, route, terminate, label, and test low-voltage cabling',
  'Read floor plans and wiring diagrams',
  'Commission systems and verify functionality',
  'Troubleshoot power, cabling, and network issues',
  'Communicate job status and site conditions to management',
  'Lead helpers and maintain clean installation standards',
  'Follow OSHA and site safety requirements',
  'Complete service reports and closeout documentation',
];

const requirements = [
  '3+ years of CCTV / low-voltage / security installation experience',
  'Experience with IP cameras, NVRs, PoE switching, and cabling',
  'Working knowledge of access control systems',
  'Ability to work from ladders, lifts, and ceilings',
  'Valid driver\'s license',
  'Strong communication skills',
  'Ability to work independently',
];

const preferred = [
  'OSHA 30',
  'NYC SST (if applicable)',
  'Experience with Hanwha, Panasonic, Axis, Pelco, Genetec, Avigilon, Milestone, Honeywell, DSC, Paxton, Brivo',
  'Basic networking (VLANs, IP addressing, troubleshooting)',
  'Experience leading small crews',
];

const compensation = [
  { label: 'NYC', value: '$33\u2013$42/hr (based on experience)' },
  { label: 'NJ', value: '$30\u2013$40/hr (based on experience)' },
  { label: 'Overtime', value: 'Available' },
];

const perks = [
  'Company vehicle or allowance',
  'Tools allowance',
];
---

<BaseLayout
  title="Careers | Join VKC Systems"
  description="Join VKC Systems. We're hiring experienced low-voltage and security technicians for transit and infrastructure projects across NYC and NJ."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Careers</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Join Our Team
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        We're looking for skilled professionals who take pride in their work and want to build critical infrastructure across the NYC metro area.
      </p>
    </div>
  </section>

  <!-- Why VKC -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Why VKC Systems</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
          Build Systems That Matter
        </h2>
        <p class="mt-4 text-lg text-vkc-gray leading-relaxed">
          At VKC Systems, you'll work on real infrastructure — CCTV, access control, networking, and communication systems for transit agencies and public sector clients. Our team works on projects for the MTA, NJ Transit, Port Authority, and more.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-gray-100 bg-vkc-light p-6 text-center">
          <p class="text-3xl font-extrabold text-vkc-red">10+</p>
          <p class="mt-1 text-sm text-vkc-gray">Years in Business</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-vkc-light p-6 text-center">
          <p class="text-3xl font-extrabold text-vkc-red">8+</p>
          <p class="mt-1 text-sm text-vkc-gray">Transit Agencies Served</p>
        </div>
        <div class="rounded-xl border border-gray-100 bg-vkc-light p-6 text-center">
          <p class="text-3xl font-extrabold text-vkc-red">MBE/DBE</p>
          <p class="mt-1 text-sm text-vkc-gray">Certified Business</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Job Listing -->
  <section class="bg-vkc-light py-16 sm:py-20">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-gray-200 bg-white p-8 shadow-sm sm:p-10">
        <!-- Job Header -->
        <div class="border-b border-gray-100 pb-8">
          <div class="flex items-start justify-between flex-wrap gap-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Open Position</p>
              <h2 class="mt-2 text-2xl font-bold text-vkc-dark sm:text-3xl">
                Security / Low Voltage Lead Technician
              </h2>
            </div>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-vkc-light px-4 py-1.5 text-sm font-medium text-vkc-dark">
              <svg class="h-4 w-4 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
              NYC and/or New Jersey
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-vkc-light px-4 py-1.5 text-sm font-medium text-vkc-dark">
              <svg class="h-4 w-4 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
              Full-Time
            </span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-vkc-light px-4 py-1.5 text-sm font-medium text-vkc-dark">
              <svg class="h-4 w-4 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              $30&ndash;$42/hr
            </span>
          </div>
        </div>

        <!-- Job Summary -->
        <div class="mt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Job Summary</h3>
          <p class="mt-3 text-base leading-relaxed text-vkc-gray">
            We are hiring a hands-on Lead Technician to install, service, and troubleshoot CCTV, access control, and low-voltage systems. This role requires the ability to run jobs independently, lead junior installers, communicate with customers, and deliver clean, professional installations from rough-in through turnover.
          </p>
          <p class="mt-3 text-base leading-relaxed text-vkc-gray">
            We run organized jobs and expect high-quality workmanship&mdash;this is a role for someone who takes pride in clean installs and solving problems in the field.
          </p>
        </div>

        <!-- Responsibilities -->
        <div class="mt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Responsibilities</h3>
          <ul class="mt-3 space-y-2">
            {responsibilities.map((item) => (
              <li class="flex items-start gap-2 text-base text-vkc-gray">
                <svg class="mt-1 h-4 w-4 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Requirements -->
        <div class="mt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Must-Have</h3>
          <ul class="mt-3 space-y-2">
            {requirements.map((item) => (
              <li class="flex items-start gap-2 text-base text-vkc-gray">
                <svg class="mt-1 h-4 w-4 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Preferred -->
        <div class="mt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Nice-to-Have</h3>
          <ul class="mt-3 space-y-2">
            {preferred.map((item) => (
              <li class="flex items-start gap-2 text-base text-vkc-gray">
                <svg class="mt-1 h-4 w-4 shrink-0 text-vkc-gray" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Compensation -->
        <div class="mt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Compensation</h3>
          <div class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3">
            {compensation.map((item) => (
              <div class="rounded-lg bg-vkc-light px-4 py-3">
                <p class="text-sm font-medium text-vkc-gray">{item.label}</p>
                <p class="text-lg font-bold text-vkc-dark">{item.value}</p>
              </div>
            ))}
          </div>
          <div class="mt-4">
            <p class="text-sm font-medium text-vkc-gray mb-2">Additional benefits may include:</p>
            <ul class="flex flex-wrap gap-2">
              {perks.map((perk) => (
                <li class="inline-flex items-center rounded-full border border-gray-200 px-3 py-1 text-sm text-vkc-gray">
                  {perk}
                </li>
              ))}
            </ul>
          </div>
        </div>

        <!-- Apply CTA -->
        <div class="mt-10 border-t border-gray-100 pt-8">
          <h3 class="text-lg font-bold text-vkc-dark">Apply</h3>
          <p class="mt-2 text-base text-vkc-gray">
            If you can run jobs, troubleshoot in the field, and take pride in clean, professional installations, we want to hear from you. Send your resume and a brief description of your experience to:
          </p>
          <a
            href="mailto:careers@vkcsystems.com?subject=Application%20-%20Lead%20Technician"
            class="mt-4 inline-flex items-center gap-2 rounded-lg bg-vkc-red px-8 py-3.5 text-base font-semibold text-white shadow-sm transition-colors duration-200 hover:bg-vkc-red-dark"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            careers@vkcsystems.com
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
