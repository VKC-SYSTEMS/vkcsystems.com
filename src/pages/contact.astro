---
import BaseLayout from "../layouts/BaseLayout.astro";

const projectTypes = [
  'Network Infrastructure',
  'CCTV Systems',
  'Access Control',
  'Public Address / Intercom',
  'Communication Cabinets',
  'IT Infrastructure',
  'Other',
];

const whyVkc = [
  'Engineering-driven infrastructure solutions',
  'Experience supporting transportation and public-sector projects',
  'Certified MBE / DBE contractor',
  'Proven performance in complex system environments',
];
---

<BaseLayout
  title="Contact VKC Systems | Request a Project Consultation in NJ"
  description="Contact VKC Systems for networking, CCTV, and IT solutions. Located at 89 Leuning St, South Hackensack, NJ. Call (201) 374-0252 or use our project inquiry form."
>
  <!-- Hero Section -->
  <section class="relative bg-vkc-dark py-24 sm:py-32">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Contact</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl lg:text-6xl">
        Let's Discuss Your Infrastructure Project
      </h1>
      <p class="mx-auto mt-6 max-w-3xl text-lg leading-relaxed text-gray-300 sm:text-xl">
        Whether you're planning a new system, upgrading existing infrastructure, or need
        engineering support, our team is ready to assist.
      </p>
    </div>
  </section>

  <!-- Form + Map Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-3xl font-bold text-vkc-dark mb-2">Project Inquiry</h2>
          <p class="text-vkc-gray mb-2">
            Tell us about your project and we'll get back to you with a tailored response.
          </p>
          <p class="text-sm font-medium text-vkc-red mb-8">
            Typical Response Time: Within 1 Business Day
          </p>
          <form action="https://formsubmit.co/info@vkcsystems.com" method="POST" class="space-y-6">
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off">
            <input type="hidden" name="_next" value="https://vkcsystems.com/contact">
            <input type="hidden" name="_subject" value="New Project Inquiry - VKC Systems">
            <input type="hidden" name="_captcha" value="true">
            <div>
              <label for="name" class="block text-sm font-medium text-vkc-dark mb-1">
                Full Name <span class="text-vkc-red">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow"
                placeholder="Your full name"
              />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-vkc-dark mb-1">
                Company Name <span class="text-vkc-red">*</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow"
                placeholder="Your company name"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-vkc-dark mb-1">
                Email Address <span class="text-vkc-red">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow"
                placeholder="you@example.com"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-vkc-dark mb-1">
                Phone Number
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow"
                placeholder="(201) 555-0123"
              />
            </div>
            <fieldset>
              <legend class="block text-sm font-medium text-vkc-dark mb-2">
                Project Type <span class="text-vkc-red">*</span>
                <span class="text-xs font-normal text-vkc-gray ml-1">(select all that apply)</span>
              </legend>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {projectTypes.map((type) => (
                  <label class="flex items-center gap-2 px-3 py-2.5 border border-gray-200 rounded-lg cursor-pointer hover:border-vkc-red/30 hover:bg-red-50/30 transition-colors has-[:checked]:border-vkc-red has-[:checked]:bg-red-50/50">
                    <input
                      type="checkbox"
                      data-project-type
                      value={type}
                      class="h-4 w-4 rounded border-gray-300 text-vkc-red focus:ring-vkc-red"
                    />
                    <span class="text-sm text-vkc-dark">{type}</span>
                  </label>
                ))}
              </div>
            </fieldset>
            <div>
              <label for="location" class="block text-sm font-medium text-vkc-dark mb-1">
                Project Location
              </label>
              <input
                type="text"
                id="location"
                name="project_location"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow"
                placeholder="City, State or Site Name"
              />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-vkc-dark mb-1">
                Project Description <span class="text-vkc-red">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-vkc-red focus:border-transparent transition-shadow resize-y"
                placeholder="Tell us about your project, scope, or requirements..."
              ></textarea>
            </div>
            <input type="hidden" name="project_type" id="project-type-combined" value="" />
            <button
              type="submit"
              class="w-full bg-vkc-red hover:bg-vkc-red-dark text-white font-semibold text-lg px-8 py-4 rounded-lg transition-colors duration-200 cursor-pointer"
            >
              Submit Project Inquiry
            </button>
          </form>
          <script src="/contact-form.js" defer></script>
        </div>

        <!-- Google Maps Embed -->
        <div>
          <h2 class="text-3xl font-bold text-vkc-dark mb-2">Headquarters &mdash; New Jersey</h2>
          <p class="text-vkc-gray mb-8">
            89 Leuning St, Suite 1E, South Hackensack, NJ 07606
          </p>
          <div class="rounded-lg overflow-hidden shadow-lg h-[480px] lg:h-full lg:min-h-[480px]">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d753.0!2d-74.05282437912537!3d40.87105633995624!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c2f9ed2e518e79%3A0x75d948432c7c9ef7!2s89%20Leuning%20St%2C%20South%20Hackensack%2C%20NJ%2007606!5e0!3m2!1sen!2sus!4v1713460166797!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0;"
              sandbox="allow-scripts allow-same-origin allow-popups allow-popups-to-escape-sandbox"
              loading="lazy"
              referrerpolicy="no-referrer"
              title="VKC Systems office location on Google Maps"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Work With VKC -->
  <section class="bg-vkc-light py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Why VKC</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
          Why Work With VKC Systems
        </h2>
      </div>
      <div class="mx-auto mt-10 max-w-3xl">
        <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2">
          {whyVkc.map((item) => (
            <li class="flex items-start gap-3 rounded-xl border border-gray-100 bg-white p-5 shadow-sm">
              <svg
                class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2.5"
                stroke="currentColor"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
              <span class="text-base font-medium text-vkc-dark">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Contact Info Cards -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Phone -->
        <div class="bg-vkc-light rounded-lg shadow-sm p-8 text-center">
          <div class="w-14 h-14 bg-vkc-red/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-vkc-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-vkc-dark mb-2">Phone</h3>
          <a href="tel:2013740252" class="text-vkc-gray hover:text-vkc-red transition-colors">
            (201) 374-0252
          </a>
        </div>

        <!-- Email -->
        <div class="bg-vkc-light rounded-lg shadow-sm p-8 text-center">
          <div class="w-14 h-14 bg-vkc-red/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-vkc-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-vkc-dark mb-2">Email</h3>
          <a href="mailto:info@vkcsystems.com" class="text-vkc-gray hover:text-vkc-red transition-colors">
            info@vkcsystems.com
          </a>
        </div>

        <!-- Address -->
        <div class="bg-vkc-light rounded-lg shadow-sm p-8 text-center">
          <div class="w-14 h-14 bg-vkc-red/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-vkc-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-vkc-dark mb-2">Address</h3>
          <a
            href="https://maps.app.goo.gl/1QhGiqvSpyeyxvTH9"
            target="_blank"
            rel="noopener noreferrer"
            class="text-vkc-gray hover:text-vkc-red transition-colors hover:underline"
          >
            89 Leuning St Suite 1E<br />
            South Hackensack, NJ 07606
          </a>
        </div>

        <!-- Hours -->
        <div class="bg-vkc-light rounded-lg shadow-sm p-8 text-center">
          <div class="w-14 h-14 bg-vkc-red/10 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-7 h-7 text-vkc-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-lg font-bold text-vkc-dark mb-2">Hours</h3>
          <p class="text-vkc-gray">
            Monday &ndash; Friday<br />
            7:00 AM &ndash; 3:00 PM
          </p>
        </div>
      </div>

      <p class="mt-10 text-center text-base text-vkc-gray">
        Serving clients throughout the New York metropolitan area and surrounding regions.
      </p>
    </div>
  </section>
</BaseLayout>
