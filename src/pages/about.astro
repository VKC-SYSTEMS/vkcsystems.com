---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About VKC Systems | MBE/DBE Systems Integrator Since 2014"
  description="Founded in 2014, VKC Systems is an MBE/DBE systems integrator serving MTA, NYCT, LIRR, NJT, Port Authority, and commercial clients across the NYC metro area."
>
  <!-- Hero Section -->
  <section class="bg-vkc-dark py-24 md:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-white tracking-tight">
        About VKC Systems
      </h1>
      <div class="mt-4 w-20 h-1 bg-vkc-red mx-auto rounded-full"></div>
    </div>
  </section>

  <!-- Story Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-vkc-dark mb-8">
        Our Story
      </h2>
      <p class="text-lg md:text-xl leading-relaxed text-vkc-gray mb-6">
        VKC Systems was founded in 2014 by the Cepeda brothers in Mount Vernon, NY. What began
        as a focused operation has grown into a full-service systems integrator now headquartered
        in South Hackensack, NJ. That growth is the direct result of consistent, on-time project
        delivery and a reputation for technical excellence in demanding environments.
      </p>
      <p class="text-lg md:text-xl leading-relaxed text-vkc-gray">
        Today, we provide end-to-end communication and network integration services &mdash; from
        custom cabinet fabrication and fiber optic termination to CCTV engineering, network
        engineering, and 24-hour service maintenance. Every project is completed on schedule,
        within budget, and to the standards our clients expect.
      </p>
    </div>
  </section>

  <!-- Highlight Box -->
  <section class="py-12 md:py-16 bg-vkc-light">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-white border-l-4 border-vkc-red rounded-lg shadow-lg p-8 md:p-12">
        <p class="text-xl md:text-2xl font-semibold text-vkc-dark leading-relaxed">
          VKC Systems, Inc. is a certified MBE/DBE specializing in mass transit systems
          integration across the New York City metropolitan area.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section class="py-16 md:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl md:text-4xl font-bold text-vkc-dark mb-8">
        What We Do
      </h2>
      <p class="text-lg md:text-xl leading-relaxed text-vkc-gray">
        Our scope of work includes closed-circuit television, intercoms, security alarm systems,
        train dispatch, customer information signs, data networks, gate control, telephone, and
        VoIP systems. Our technical experts specialize in network upgrades and redesigns that
        improve the reliability of data-dependent transit and commercial infrastructure.
      </p>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 md:py-24 bg-vkc-dark">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-xl md:text-2xl text-white mb-8">
        Let's discuss how VKC Systems can support your next project.
      </p>
      <a
        href="/contact"
        class="inline-block bg-vkc-red hover:bg-vkc-red-dark text-white font-semibold text-lg px-8 py-4 rounded-lg transition-colors duration-200"
      >
        Contact Us
      </a>
    </div>
  </section>
</BaseLayout>
