---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="VKC Systems | Systems Integration & IT Solutions in NJ"
  description="MBE/DBE systems integrator specializing in networking, CCTV, access control, and communication solutions for transit and commercial clients in the NYC metro area."
>
  <!-- ============================================ -->
  <!--                HERO SECTION                  -->
  <!-- ============================================ -->
  <section class="relative min-h-screen flex items-center bg-vkc-dark text-white overflow-hidden">
    <!-- Background video -->
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
    >
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay for text readability -->
    <div class="absolute inset-0 bg-vkc-dark/70"></div>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-6 py-32 lg:py-40">
      <div class="max-w-3xl">
        <!-- Certification label -->
        <span class="inline-block rounded-full border border-vkc-red/40 bg-vkc-red/10 px-4 py-1.5 text-xs font-semibold tracking-widest text-vkc-red uppercase mb-6">
          MBE/DBE Certified Systems Integrator
        </span>

        <!-- Main heading -->
        <h1 class="text-4xl font-extrabold leading-tight tracking-tight sm:text-5xl lg:text-6xl xl:text-7xl">
          Engineering the Future of
          <span class="text-vkc-red">Transit Infrastructure</span>
        </h1>

        <!-- Subtext -->
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-zinc-400 sm:text-xl">
          VKC Systems delivers end-to-end communication and network integration
          solutions for transit agencies, government clients, and commercial facilities across the NYC metro area.
        </p>

        <!-- CTA buttons -->
        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href="/solutions"
            class="inline-flex items-center rounded-md bg-vkc-red px-8 py-3.5 text-sm font-semibold text-white shadow-lg shadow-vkc-red/25 transition hover:bg-vkc-red-dark focus:outline-none focus:ring-2 focus:ring-vkc-red focus:ring-offset-2 focus:ring-offset-vkc-dark"
          >
            View Our Solutions
          </a>
          <a
            href="/contact"
            class="inline-flex items-center rounded-md border border-zinc-600 px-8 py-3.5 text-sm font-semibold text-white transition hover:border-white hover:bg-white/5 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-vkc-dark"
          >
            Contact Us
          </a>
        </div>
      </div>

      <!-- Stats row -->
      <div class="mt-20 grid grid-cols-1 gap-8 border-t border-zinc-800 pt-10 sm:grid-cols-3 lg:mt-28">
        <div>
          <p class="text-3xl font-bold text-white sm:text-4xl">Since 2014</p>
          <p class="mt-1 text-sm font-medium tracking-wide text-zinc-500 uppercase">Established</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white sm:text-4xl">8+</p>
          <p class="mt-1 text-sm font-medium tracking-wide text-zinc-500 uppercase">Transit & Government Agencies Served</p>
        </div>
        <div>
          <p class="text-3xl font-bold text-white sm:text-4xl">24/7</p>
          <p class="mt-1 text-sm font-medium tracking-wide text-zinc-500 uppercase">Service & Support</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!--              SERVICES GRID                   -->
  <!-- ============================================ -->
  <section class="bg-white py-24 sm:py-32">
    <div class="mx-auto max-w-7xl px-6">
      <!-- Section header -->
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold tracking-widest text-vkc-red uppercase">What We Do</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-zinc-900 sm:text-4xl lg:text-5xl">
          Our Solutions
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-vkc-gray">
          Comprehensive systems integration services tailored for critical infrastructure and commercial environments.
        </p>
      </div>

      <!-- Service cards grid -->
      <div class="mt-16 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Networking -->
        <a href="/solutions/networking" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128268;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">Networking</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Fiber optic infrastructure, network design, and enterprise Wi-Fi solutions for mission-critical environments.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- CCTV -->
        <a href="/solutions/cctv" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128247;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">CCTV</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Surveillance security systems with custom cabinet solutions designed for demanding transit environments.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- Public Address Systems -->
        <a href="/solutions/public-address" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128226;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">Public Address Systems</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            PA and intercom systems engineered for harsh environments and high-traffic transit facilities.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- Access Control -->
        <a href="/solutions/access-control" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128274;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">Access Control</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Lenel-integrated access control systems providing secure entry management for facilities of any scale.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- Communication Cabinets -->
        <a href="/solutions/communication-cabinets" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128451;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">Communication Cabinets</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Custom-fabricated communication cabinets and enclosures built to spec for transit and industrial applications.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- CADD Services -->
        <a href="/solutions/cadd" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128208;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">CADD Services</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Professional AutoCAD drafting and technical drawings for infrastructure planning and documentation.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- VoIP -->
        <a href="/solutions/voip" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128222;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">VoIP</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Modern business phone systems with VoIP technology for reliable, cost-effective communications.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>

        <!-- Office IT -->
        <a href="/solutions/office-it" class="group relative rounded-xl border border-zinc-200 bg-white p-6 transition hover:border-vkc-red/30 hover:shadow-lg hover:shadow-vkc-red/5">
          <div class="flex h-12 w-12 items-center justify-center rounded-lg bg-vkc-red/10 text-2xl">
            <span>&#128187;</span>
          </div>
          <h3 class="mt-4 text-lg font-semibold text-zinc-900 group-hover:text-vkc-red transition">Office IT</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">
            Managed IT services, workstation setup, and ongoing technical support to keep your business running.
          </p>
          <span class="mt-4 inline-flex items-center text-sm font-medium text-vkc-red opacity-0 transition group-hover:opacity-100">
            Learn More &rarr;
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!--            TRUSTED BY SECTION                -->
  <!-- ============================================ -->
  <section class="bg-vkc-dark py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Trusted By</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-white sm:text-3xl">
          Serving the Tri-State Area's Leading Agencies
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">MTA</p>
          <p class="mt-1 text-sm text-gray-400">Metropolitan Transportation Authority</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">NYCT</p>
          <p class="mt-1 text-sm text-gray-400">New York City Transit</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">LIRR</p>
          <p class="mt-1 text-sm text-gray-400">Long Island Rail Road</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">TBTA</p>
          <p class="mt-1 text-sm text-gray-400">Triborough Bridge &amp; Tunnel Authority</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">Metro-North</p>
          <p class="mt-1 text-sm text-gray-400">Metro-North Railroad</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">NJT</p>
          <p class="mt-1 text-sm text-gray-400">New Jersey Transit</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">Port Authority</p>
          <p class="mt-1 text-sm text-gray-400">Port Authority of NY &amp; NJ</p>
        </div>
        <div class="rounded-xl border border-white/10 bg-white/5 px-6 py-5 text-center">
          <p class="text-lg font-bold text-white">NYC DEP</p>
          <p class="mt-1 text-sm text-gray-400">NYC Dept. of Environmental Protection</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!--          CERTIFICATIONS SECTION              -->
  <!-- ============================================ -->
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Credentials</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
          Certifications &amp; Qualifications
        </h2>
      </div>

      <div class="mt-12 flex flex-wrap items-center justify-center gap-4">
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">MBE Certified</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">DBE Certified</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">OSHA 30</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">Track Safety Training</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">CSPM</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">CompTIA Network+</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">Cisco CCNA</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">Cisco CCNP</span>
        <span class="rounded-full border border-gray-200 bg-vkc-light px-5 py-2.5 text-sm font-semibold text-vkc-dark">Technical Experts</span>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!--           WHY CHOOSE VKC SECTION             -->
  <!-- ============================================ -->
  <section class="bg-vkc-light py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Why VKC</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
          What Sets Us Apart
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-vkc-red/10">
            <svg class="h-7 w-7 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-vkc-dark">MBE/DBE Certified</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">Minority and Disadvantaged Business Enterprise certified, meeting diversity requirements for public projects.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-vkc-red/10">
            <svg class="h-7 w-7 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.048.58.024 1.194-.14 1.743" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-vkc-dark">End-to-End Expertise</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">From engineering and design through programming and commissioning — we handle every phase of your project.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-vkc-red/10">
            <svg class="h-7 w-7 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-vkc-dark">On Time, On Budget</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">Every project delivered on schedule and within budget, meeting the rigorous standards our transit agency clients expect.</p>
        </div>
        <div class="text-center">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-vkc-red/10">
            <svg class="h-7 w-7 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
            </svg>
          </div>
          <h3 class="mt-4 text-lg font-bold text-vkc-dark">24/7 Support</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">Around-the-clock service and maintenance support to keep your critical infrastructure running without interruption.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!--          INDUSTRIES SERVED SECTION            -->
  <!-- ============================================ -->
  <section class="bg-white py-20 sm:py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-vkc-red">Industries</p>
        <h2 class="mt-3 text-2xl font-bold tracking-tight text-vkc-dark sm:text-3xl">
          Industries We Serve
        </h2>
      </div>

      <div class="mt-14 grid grid-cols-1 gap-6 sm:grid-cols-3">
        <div class="group rounded-2xl border border-gray-100 bg-vkc-light p-8 text-center transition-all duration-300 hover:shadow-lg hover:border-vkc-red/20">
          <svg class="mx-auto h-10 w-10 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0H21M3.375 14.25h17.25M3.375 14.25V3.375c0-.621.504-1.125 1.125-1.125h9.75c.621 0 1.125.504 1.125 1.125v10.875m-12 0h12m0 0h2.25a1.125 1.125 0 0 1 1.056.744l1.134 3.177" />
          </svg>
          <h3 class="mt-5 text-lg font-bold text-vkc-dark">Mass Transit</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">Subway systems, commuter rail, tunnels, bridges, and station infrastructure across the NYC tri-state area.</p>
        </div>
        <div class="group rounded-2xl border border-gray-100 bg-vkc-light p-8 text-center transition-all duration-300 hover:shadow-lg hover:border-vkc-red/20">
          <svg class="mx-auto h-10 w-10 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" />
          </svg>
          <h3 class="mt-5 text-lg font-bold text-vkc-dark">Government Infrastructure</h3>
          <p class="mt-2 text-sm leading-relaxed text-vkc-gray">Federal, state, and municipal facilities requiring secure, compliant communication and network systems.</p>
        </div>
        <div class="group rounded-2xl border border-gray-100 bg-vkc-light p-8 text-center transition-all duration-300 hover:shadow-lg hover:border-vkc-red/20">
          <svg class="mx-auto h-10 w-10 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
