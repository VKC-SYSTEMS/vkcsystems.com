---
import BaseLayout from '../layouts/BaseLayout.astro';

const sections = [
  { id: 'collect', label: 'Information We Collect' },
  { id: 'use', label: 'How We Use It' },
  { id: 'third-party', label: 'Third-Party Services' },
  { id: 'retention', label: 'Data Retention' },
  { id: 'security', label: 'Data Security' },
  { id: 'cookies', label: 'Cookies' },
  { id: 'children', label: "Children's Privacy" },
  { id: 'rights', label: 'Your Rights' },
  { id: 'changes', label: 'Policy Changes' },
  { id: 'contact', label: 'Contact Us' },
];
---

<BaseLayout
  title="Privacy Policy | VKC Systems"
  description="VKC Systems privacy policy. How we collect, use, and protect your information."
>
  <!-- Hero -->
  <section class="relative bg-vkc-dark py-20 sm:py-24">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-br from-vkc-dark via-gray-900 to-vkc-dark"></div>
      <div class="absolute top-0 right-0 h-96 w-96 rounded-full bg-vkc-red/5 blur-3xl"></div>
    </div>
    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-vkc-red">Legal</p>
      <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
        Privacy Policy
      </h1>
      <p class="mx-auto mt-4 max-w-xl text-base text-gray-400">
        Effective April 23, 2026 &mdash; VKC Systems Inc.
      </p>
    </div>
  </section>

  <!-- Content -->
  <section class="bg-white py-16 sm:py-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-[240px_1fr] lg:gap-16">

        <!-- Sidebar Nav (sticky) -->
        <aside class="hidden lg:block">
          <nav class="sticky top-24 space-y-1">
            <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-vkc-gray">On this page</p>
            {sections.map((s) => (
              <a
                href={`#${s.id}`}
                class="block rounded-md px-3 py-2 text-sm text-vkc-gray transition-colors hover:bg-vkc-light hover:text-vkc-dark"
              >
                {s.label}
              </a>
            ))}
          </nav>
        </aside>

        <!-- Main Content -->
        <div class="max-w-3xl">
          <!-- Intro -->
          <div class="rounded-xl border border-gray-100 bg-vkc-light p-6 sm:p-8">
            <p class="text-base leading-relaxed text-vkc-gray">
              VKC Systems Inc. ("VKC Systems," "we," "us," or "our") respects your privacy and is committed to protecting the personal information you share with us. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit <strong class="text-vkc-dark">vkcsystems.com</strong> or contact us through our inquiry forms.
            </p>
          </div>

          <div class="mt-12 space-y-14">
            <!-- Information We Collect -->
            <div id="collect" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Information We Collect</h2>
              </div>
              <div class="grid gap-4 sm:grid-cols-2">
                <div class="rounded-xl border border-gray-100 p-5">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-vkc-red">You Provide</h3>
                  <ul class="mt-3 space-y-2 text-sm text-vkc-gray">
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>Name, email, phone, and company via inquiry forms</li>
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>Project details and service interests</li>
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>Resumes submitted through our careers page</li>
                  </ul>
                </div>
                <div class="rounded-xl border border-gray-100 p-5">
                  <h3 class="text-sm font-semibold uppercase tracking-wide text-vkc-red">Collected Automatically</h3>
                  <ul class="mt-3 space-y-2 text-sm text-vkc-gray">
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>Browser type, OS, and device information</li>
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>Pages visited and time on site</li>
                    <li class="flex gap-2"><span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-vkc-red"></span>IP address and approximate location</li>
                  </ul>
                </div>
              </div>
              <p class="mt-4 text-sm text-vkc-gray">
                We use <strong class="text-vkc-dark">Vercel Analytics</strong> to collect anonymized usage data. It does not use cookies and does not collect personally identifiable information.
              </p>
            </div>

            <!-- How We Use It -->
            <div id="use" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">How We Use Your Information</h2>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="flex items-start gap-3 rounded-lg border border-gray-100 p-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <p class="text-sm text-vkc-gray">Respond to project inquiries and consultation requests</p>
                </div>
                <div class="flex items-start gap-3 rounded-lg border border-gray-100 p-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <p class="text-sm text-vkc-gray">Evaluate employment applications</p>
                </div>
                <div class="flex items-start gap-3 rounded-lg border border-gray-100 p-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <p class="text-sm text-vkc-gray">Improve our website and user experience</p>
                </div>
                <div class="flex items-start gap-3 rounded-lg border border-gray-100 p-4">
                  <svg class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>
                  <p class="text-sm text-vkc-gray">Communicate regarding services and follow-ups</p>
                </div>
              </div>
              <div class="mt-4 rounded-lg bg-vkc-light px-4 py-3">
                <p class="text-sm font-medium text-vkc-dark">We do not sell, rent, or trade your personal information to third parties for marketing purposes.</p>
              </div>
            </div>

            <!-- Third-Party Services -->
            <div id="third-party" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Third-Party Services</h2>
              </div>
              <div class="grid gap-3 sm:grid-cols-3">
                <div class="rounded-xl border border-gray-100 p-5 text-center">
                  <p class="text-sm font-bold text-vkc-dark">Vercel</p>
                  <p class="mt-1 text-xs text-vkc-gray">Hosting &amp; anonymized analytics</p>
                </div>
                <div class="rounded-xl border border-gray-100 p-5 text-center">
                  <p class="text-sm font-bold text-vkc-dark">FormSubmit</p>
                  <p class="mt-1 text-xs text-vkc-gray">Contact form processing</p>
                </div>
                <div class="rounded-xl border border-gray-100 p-5 text-center">
                  <p class="text-sm font-bold text-vkc-dark">Google Maps</p>
                  <p class="mt-1 text-xs text-vkc-gray">Embedded map on contact page</p>
                </div>
              </div>
              <p class="mt-4 text-sm text-vkc-gray">
                Each service has its own privacy policy. We encourage you to review their policies.
              </p>
            </div>

            <!-- Data Retention -->
            <div id="retention" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Data Retention</h2>
              </div>
              <p class="text-sm leading-relaxed text-vkc-gray">
                We retain personal information only for as long as necessary to fulfill the purposes outlined in this policy, respond to your inquiries, or comply with legal requirements. Contact form submissions and employment applications are retained for a reasonable period and then securely deleted.
              </p>
            </div>

            <!-- Data Security -->
            <div id="security" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Data Security</h2>
              </div>
              <p class="text-sm leading-relaxed text-vkc-gray">
                We implement reasonable administrative, technical, and physical security measures to protect your personal information. Our website is served over HTTPS with security headers including Content Security Policy, HSTS, and X-Frame-Options. However, no method of transmission over the internet is 100% secure.
              </p>
            </div>

            <!-- Cookies -->
            <div id="cookies" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Cookies</h2>
              </div>
              <div class="rounded-lg bg-vkc-light px-4 py-3">
                <p class="text-sm text-vkc-gray">
                  Our website <strong class="text-vkc-dark">does not use cookies</strong> for tracking or advertising. Vercel Analytics is cookie-free and privacy-focused.
                </p>
              </div>
            </div>

            <!-- Children's Privacy -->
            <div id="children" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Children's Privacy</h2>
              </div>
              <p class="text-sm leading-relaxed text-vkc-gray">
                Our website and services are not directed to individuals under the age of 18. We do not knowingly collect personal information from children. If you believe we have inadvertently collected information from a minor, please contact us and we will promptly delete it.
              </p>
            </div>

            <!-- Your Rights -->
            <div id="rights" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Your Rights</h2>
              </div>
              <p class="text-sm leading-relaxed text-vkc-gray">
                Depending on your jurisdiction, you may have the right to access, correct, delete, or restrict the processing of your personal information. To exercise any of these rights, please contact us using the information below.
              </p>
            </div>

            <!-- Changes -->
            <div id="changes" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Changes to This Policy</h2>
              </div>
              <p class="text-sm leading-relaxed text-vkc-gray">
                We may update this Privacy Policy from time to time. Changes will be posted on this page with an updated effective date.
              </p>
            </div>

            <!-- Contact -->
            <div id="contact" class="scroll-mt-24">
              <div class="flex items-center gap-3 mb-4">
                <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-vkc-red/10">
                  <svg class="h-5 w-5 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                </div>
                <h2 class="text-xl font-bold text-vkc-dark">Contact Us</h2>
              </div>
              <p class="text-sm text-vkc-gray mb-4">If you have questions about this Privacy Policy or how we handle your data:</p>
              <div class="rounded-xl border border-gray-100 bg-vkc-light p-6">
                <p class="font-semibold text-vkc-dark">VKC Systems Inc.</p>
                <p class="mt-1 text-sm text-vkc-gray">89 Leuning St, Suite 1E, South Hackensack, NJ 07606</p>
                <div class="mt-4 flex flex-wrap gap-4">
                  <a href="tel:2013740252" class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-medium text-vkc-dark shadow-sm transition hover:shadow-md">
                    <svg class="h-4 w-4 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" /></svg>
                    (201) 374-0252
                  </a>
                  <a href="mailto:info@vkcsystems.com" class="inline-flex items-center gap-2 rounded-lg bg-white px-4 py-2 text-sm font-medium text-vkc-dark shadow-sm transition hover:shadow-md">
                    <svg class="h-4 w-4 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" /></svg>
                    info@vkcsystems.com
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
