---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | VKC Systems"
  description="The page you're looking for doesn't exist or has been moved."
>
  <section class="flex min-h-[60vh] items-center justify-center px-6 py-24">
    <div class="text-center">
      <p class="text-sm font-semibold uppercase tracking-wide text-vkc-red">404 Error</p>
      <h1 class="mt-2 text-4xl font-bold text-vkc-dark sm:text-5xl">Page not found</h1>
      <p class="mt-4 text-lg text-vkc-gray">Sorry, the page you're looking for doesn't exist or has been moved.</p>
      <div class="mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href="/"
          class="inline-block rounded-md bg-vkc-red px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-red-700"
        >
          Go to Homepage
        </a>
        <a
          href="/contact"
          class="inline-block rounded-md border border-vkc-dark/20 px-6 py-3 text-sm font-semibold text-vkc-dark transition hover:bg-vkc-light"
        >
          Contact Us
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
