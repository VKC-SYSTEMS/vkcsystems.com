---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/solutions', label: 'Solutions' },
  { href: '/projects', label: 'Projects' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-white transition-shadow duration-300"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-18 items-center justify-between">
      <!-- Logo -->
      <a href="/" class="flex shrink-0 items-center">
        <img src="/logo.svg" alt="VKC Systems" class="h-10 w-auto max-w-[180px] sm:h-14 sm:max-w-none" />
      </a>

      <!-- Desktop Nav -->
      <nav class="hidden items-center gap-1 md:flex" aria-label="Primary navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'relative px-4 py-2 text-sm font-medium transition-colors duration-200',
              isActive(link.href)
                ? 'text-vkc-red'
                : 'text-vkc-dark hover:text-vkc-red',
            ]}
          >
            {link.label}
            {isActive(link.href) && (
              <span class="absolute bottom-0 left-4 right-4 h-0.5 rounded-full bg-vkc-red" />
            )}
          </a>
        ))}
        <a
          href="/contact"
          class="ml-4 inline-flex items-center rounded-lg bg-vkc-red px-5 py-2.5 text-sm font-semibold text-white transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Get a Quote
        </a>
      </nav>

      <!-- Mobile Hamburger -->
      <button
        id="menu-toggle"
        class="relative z-[60] flex h-10 w-10 items-center justify-center rounded-lg text-vkc-dark transition-colors hover:bg-gray-100 md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span id="hamburger-icon" class="space-y-1.5">
          <span class="block h-0.5 w-6 origin-center bg-current transition-all duration-300" id="bar1"></span>
          <span class="block h-0.5 w-6 bg-current transition-all duration-300" id="bar2"></span>
          <span class="block h-0.5 w-6 origin-center bg-current transition-all duration-300" id="bar3"></span>
        </span>
      </button>
    </div>
  </div>

  <!-- Mobile Slide-out Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-40 translate-x-full transition-transform duration-300 ease-in-out md:hidden"
  >
    <!-- Overlay -->
    <div id="menu-overlay" class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"></div>

    <!-- Panel -->
    <div class="absolute top-0 right-0 bottom-0 w-72 bg-white shadow-2xl">
      <nav class="flex flex-col gap-1 px-6 pt-24" aria-label="Mobile navigation">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-4 py-3 text-base font-medium transition-colors duration-200',
              isActive(link.href)
                ? 'bg-red-50 text-vkc-red'
                : 'text-vkc-dark hover:bg-gray-50 hover:text-vkc-red',
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href="/contact"
          class="mt-4 inline-flex items-center justify-center rounded-lg bg-vkc-red px-5 py-3 text-base font-semibold text-white transition-colors duration-200 hover:bg-vkc-red-dark"
        >
          Get a Quote
        </a>
      </nav>

      <!-- Mobile contact info -->
      <div class="absolute bottom-8 left-6 right-6 space-y-2 border-t border-gray-100 pt-6">
        <a href="tel:2013740252" class="block text-sm text-vkc-gray hover:text-vkc-red">
          (201) 374-0252
        </a>
        <a href="mailto:info@vkcsystems.com" class="block text-sm text-vkc-gray hover:text-vkc-red">
          info@vkcsystems.com
        </a>
      </div>
    </div>
  </div>
</header>

<!-- Spacer to offset fixed header -->
<div class="h-18"></div>

<script src="/menu.js" defer></script>
