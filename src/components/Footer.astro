---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white text-vkc-dark">
  <!-- Main footer content -->
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <!-- Logo -->
    <div class="mb-10">
      <a href="/">
        <img src="/logo.svg" alt="VKC Systems" class="h-10 w-auto" />
      </a>
    </div>

    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-3">

      <!-- Hours -->
      <div>
        <h3 class="mb-4 text-lg font-bold tracking-wide uppercase">Hours</h3>
        <div class="space-y-2 text-sm leading-relaxed text-vkc-gray">
          <p>
            <span class="font-medium text-vkc-dark">Monday &ndash; Friday</span><br />
            7:00 AM &ndash; 3:00 PM
          </p>
          <p>
            <span class="font-medium text-vkc-dark">Saturday &ndash; Sunday</span><br />
            Closed
          </p>
        </div>
      </div>

      <!-- Address -->
      <div>
        <h3 class="mb-4 text-lg font-bold tracking-wide uppercase">Address</h3>
        <a
          href="https://maps.app.goo.gl/1QhGiqvSpyeyxvTH9"
          target="_blank"
          rel="noopener noreferrer"
          class="group inline-flex items-start gap-2 text-sm leading-relaxed text-vkc-gray transition-colors hover:text-vkc-red"
        >
          <!-- Map pin icon -->
          <svg class="mt-0.5 h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span class="group-hover:underline">
            89 Leuning St Suite 1E<br />
            South Hackensack, NJ 07606
          </span>
        </a>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="mb-4 text-lg font-bold tracking-wide uppercase">Contact</h3>
        <div class="space-y-3 text-sm">
          <a
            href="tel:2013740252"
            class="flex items-center gap-2 text-vkc-gray transition-colors hover:text-vkc-red"
          >
            <!-- Phone icon -->
            <svg class="h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <span class="hover:underline">(201) 374-0252</span>
          </a>
          <a
            href="mailto:info@vkcsystems.com"
            class="flex items-center gap-2 text-vkc-gray transition-colors hover:text-vkc-red"
          >
            <!-- Email icon -->
            <svg class="h-5 w-5 shrink-0 text-vkc-red" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <span class="hover:underline">info@vkcsystems.com</span>
          </a>
        </div>
      </div>

    </div>

    <!-- Capability Statement -->
    <div class="mt-10 border-t border-gray-200 pt-8">
      <a
        href="/VKC-Systems-Infrastructure-Capabilities-Statement.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-sm font-semibold text-vkc-red transition-colors hover:text-vkc-red-dark"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Download Capabilities Statement
      </a>
    </div>

    <!-- Social Icons -->
    <div class="mt-8 flex items-center gap-4 border-t border-gray-200 pt-8">
      <span class="mr-2 text-sm font-medium text-vkc-gray">Follow Us</span>
      <a
        href="https://www.facebook.com/VKCSYSTEMS/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        class="flex h-10 w-10 items-center justify-center rounded-full bg-vkc-red/10 text-vkc-red transition-colors hover:bg-vkc-red hover:text-white"
      >
        <!-- Facebook SVG -->
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
        </svg>
      </a>
      <a
        href="https://www.instagram.com/vkcsystems/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="flex h-10 w-10 items-center justify-center rounded-full bg-vkc-red/10 text-vkc-red transition-colors hover:bg-vkc-red hover:text-white"
      >
        <!-- Instagram SVG -->
        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Copyright bar -->
  <div class="border-t border-gray-200 bg-vkc-light">
    <div class="mx-auto max-w-7xl px-4 py-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm text-vkc-gray">
        &copy; {currentYear} VKC Systems, Inc. All rights reserved.
      </p>
    </div>
  </div>
</footer>
